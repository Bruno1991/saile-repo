<?xml version="1.0" encoding="UTF-8"?>
<addons>
<addon id="plugin.video.saile.mc" version="1.0.0" name="Saile IPTV" provider-name="Dev">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="main.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="pt_BR">Cliente leve para Xtream Codes API</summary>
    <platform>all</platform>
  </extension>
</addon>

<addon
    id="repository.saile"
    name="SAILE Repository"
    version="1.0.0"
    provider-name="Bruno1991">

    <extension point="xbmc.addon.repository">

        <dir>

            <info compressed="false">
            https://bruno1991.github.io/saile-repo/addons.xml
            </info>

            <checksum>
            https://bruno1991.github.io/saile-repo/addons.xml.sha256
            </checksum>

            <datadir zip="true">
            https://bruno1991.github.io/saile-repo/
            </datadir>

        </dir>

    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>Repositório oficial SAILE</summary>
        <description>Repositório oficial do addon SAILE IPTV.</description>
        <platform>all</platform>
    </extension>

</addon>

</addons>
