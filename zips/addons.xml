<?xml version="1.0" encoding="UTF-8"?>
<addons>
<addon id="plugin.video.saile.mc" version="1.0.7" name="Saile IPTV" provider-name="Dev">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="main.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="pt_BR">Cliente leve para Xtream Codes API</summary>
    <platform>all</platform>
    <assets>
      <icon>icon.png</icon>
    </assets>
  </extension>
</addon>

<addon
    id="repository.saile"
    name="SAILE Repository"
    version="1.0.4"
    provider-name="Bruno1991">

    <extension point="xbmc.addon.repository">

        <dir>

            <info compressed="false">https://raw.githubusercontent.com/Bruno1991/saile-repo/main/zips/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/Bruno1991/saile-repo/main/zips/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/Bruno1991/saile-repo/main/zips/</datadir>

        </dir>

    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>Repositório oficial SAILE</summary>
        <description>Repositório oficial do addon SAILE IPTV.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>

</addon>

</addons>
